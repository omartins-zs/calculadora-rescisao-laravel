#!/bin/sh

echo "---------------------------------------"
echo "Iniciando Hooks de Pre-Push..."
echo "---------------------------------------"

echo "[1/3] Rodando bateria de testes..."
php artisan test
TEST_STATUS=$?

if [ $TEST_STATUS -ne 0 ]; then
    echo "[ERRO] Falha nos testes de integridade da aplicacao."
    echo "Push abortado. Corrija os testes antes de enviar."
    exit 1
fi

echo "Testes OK."

echo "[2/3] Rodando Laravel Pint..."
./vendor/bin/pint --test
PINT_STATUS=$?

if [ $PINT_STATUS -ne 0 ]; then
    echo "[ERRO] Laravel Pint encontrou problemas de formatacao no codigo."
    echo "Push abortado."
    exit 1
fi

echo "Pint OK."

echo "[3/3] Rodando Larastan..."
./vendor/bin/phpstan analyse --level=5 --memory-limit=1G
STAN_STATUS=$?

if [ $STAN_STATUS -ne 0 ]; then
    echo "[ERRO] Larastan encontrou falhas ao revisar o codigo final."
    echo "Push abortado."
    exit 1
fi

echo "Larastan OK."
echo "Subindo codigo..."

exit 0

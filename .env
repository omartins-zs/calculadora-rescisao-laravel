############################################
# APP
############################################

APP_NAME="Calculadora de Rescisão Trabalhista"
APP_KEY=base64:z4a7yBV/pish58seNbvyWyvyrWNk8BvQEqYQwmlrVuk=
APP_DEBUG=true

# Local
APP_ENV=local
APP_URL=http://localhost:8084
APP_PORT=8084

# Docker
# APP_ENV=docker
# APP_URL=http://localhost:8000
# APP_PORT=8000

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

############################################
# DATABASE
############################################

# Local (SQLite default no Laravel)
DB_CONNECTION=sqlite
#DB_HOST=127.0.0.1
#DB_PORT=3306
#DB_DATABASE=database/database.sqlite
#DB_USERNAME=root
#DB_PASSWORD=

# Docker (PostgreSQL no container)
# DB_CONNECTION=pgsql
# DB_HOST=db_calculadora
# DB_PORT=5432
# DB_DATABASE=calculadora
# DB_USERNAME=root
# DB_PASSWORD=secret

############################################
# REDIS
############################################

# Local
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_CLIENT=phpredis

# Docker
# REDIS_HOST=redis_calculadora
# REDIS_PASSWORD=null
# REDIS_PORT=6379
# REDIS_CLIENT=phpredis

############################################
# QUEUE / CACHE / SESSION
############################################

# Em Docker usando Redis, ou DB/File local
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# Local
QUEUE_CONNECTION=sync
CACHE_STORE=file
SESSION_DRIVER=file

# Docker
# QUEUE_CONNECTION=redis
# CACHE_STORE=redis
# SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

############################################
# MAIL & OUTROS
############################################

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
